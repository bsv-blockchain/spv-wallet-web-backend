# ================================================================================================
# 🏗️ PROJECT-SPECIFIC CONFIGURATION (90-project.env)
# ================================================================================================
#
# Purpose: Project-specific overrides for spv-wallet-web-backend
# Load Order: 90 (loaded near-last, overrides all default config files)
#
# This file contains configuration specific to this project that overrides
# defaults from earlier config files (00-core, 10-*, 20-*).
#
# Override in: 99-local.env (local development only, git-ignored)
#
# ================================================================================================

# ================================================================================================
# 🎯 GO VERSION CONFIGURATION
# ================================================================================================

# Primary Go version for builds and primary test runner
GO_PRIMARY_VERSION=1.25.x

# Secondary Go version for compatibility testing
GO_SECONDARY_VERSION=1.25.x

# MAGE-X Go version overrides
MAGE_X_GO_VERSION=1.25.x
MAGE_X_GO_SECONDARY_VERSION=1.25.x

# ================================================================================================
# 📊 COVERAGE PROVIDER CONFIGURATION
# ================================================================================================

# Use Codecov as the coverage provider (overrides 10-coverage.env default of "internal")
GO_COVERAGE_PROVIDER=codecov

# Require a Codecov token for uploads
CODECOV_TOKEN_REQUIRED=true

# ================================================================================================
# 🚫 COVERAGE EXCLUSIONS (matches codecov.yml ignore paths)
# ================================================================================================

GO_COVERAGE_EXCLUDE_PATHS=.github/,.mage-cache/,.vscode/,bin/,example/,examples/,mocks/,testing/

# ================================================================================================
# 🔒 SECURITY CONFIGURATION
# ================================================================================================

# Nancy CVE Exclusions (known acceptable vulnerabilities)
NANCY_EXCLUDES=CVE-2026-4427,CVE-2026-33186,CVE-2026-34986,CVE-2026-32286,CVE-2026-33815,CVE-2026-33816,CVE-2026-5160,CVE-2026-39883

# Govulncheck/Magex CVE Exclusions
MAGE_X_CVE_EXCLUDES=CVE-2026-4427,CVE-2026-33186,CVE-2026-34986,CVE-2026-32286,CVE-2026-33815,CVE-2026-33816,CVE-2026-5160,CVE-2026-39883
